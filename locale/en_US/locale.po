msgid "plugins.generic.fileIntegrity.displayName"
msgstr "File Integrity Scanner"

msgid "plugins.generic.fileIntegrity.description"
msgstr "Proactively monitors your OJS core, Plugins, and Theme files. By comparing your installation against a trusted, official hash repository, it instantly detects unauthorized file changes, additions, or deletions."

msgid "plugins.generic.fileIntegrity.scan.run"
msgstr "Run Scan"

msgid "plugins.generic.fileIntegrity.settings.description"
msgstr "Use the form below to configure the File Integrity Scanner settings. You can exclude specific files or directories from the scan and run a manual scan at any time."

msgid "plugins.generic.fileIntegrity.settings.excludedPaths.title"
msgstr "Exclude Paths"

msgid "plugins.generic.fileIntegrity.settings.excludedPaths.description"
msgstr "Enter files or directories to exclude from the scan, one per line. Paths should be relative to the OJS base directory (e.g., 'public', 'cache/t_compile')."

msgid "plugins.generic.fileIntegrity.results.title"
msgstr "Scan Results"

msgid "plugins.generic.fileIntegrity.results.introduction"
msgstr "The following issues were found with your file installation. It is recommended that you investigate these files to ensure they have not been maliciously modified."

msgid "plugins.generic.fileIntegrity.results.noIssues"
msgstr "No file integrity issues were found. Your OJS installation appears to be clean."

msgid "plugins.generic.fileIntegrity.results.modified"
msgstr "Modified Files"

msgid "plugins.generic.fileIntegrity.results.deleted"
msgstr "Deleted Files"

msgid "plugins.generic.fileIntegrity.results.added"
msgstr "Added Files"

msgid "plugins.generic.fileIntegrity.results.filePath"
msgstr "File Path"
