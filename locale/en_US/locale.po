msgid "plugins.generic.fileIntegrity.displayName"
msgstr "File Integrity Scanner"

msgid "plugins.generic.fileIntegrity.description"
msgstr "This plugin scans your OJS installation for file integrity issues by comparing your files against the checksums of known OJS versions."

msgid "manager.plugins.settings"
msgstr "Settings"

msgid "plugins.generic.fileIntegrity.settings.introduction"
msgstr "Configure the paths to be excluded from the file integrity scan. Paths should be entered one per line."

msgid "plugins.generic.fileIntegrity.settings.excludedPaths"
msgstr "Excluded Paths"

msgid "plugins.generic.fileIntegrity.settings.excludedPaths.description"
msgstr "Enter any paths you wish to exclude from the scan, one per line. This is useful for excluding directories with custom themes or plugins."

msgid "plugins.generic.fileIntegrity.settings.scan.description"
msgstr "Run a manual scan to check the integrity of your OJS files now. This may take a few moments."

msgid "plugins.generic.fileIntegrity.settings.scan.button"
msgstr "Run Manual Scan"

msgid "plugins.generic.fileIntegrity.results.mismatched"
msgstr "Mismatched Files"

msgid "plugins.generic.fileIntegrity.results.missing"
msgstr "Missing Files"

msgid "plugins.generic.fileIntegrity.results.none"
msgstr "No issues found."

msgid "common.save"
msgstr "Save"
